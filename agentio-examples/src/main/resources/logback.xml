<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- AgentIO framework logging -->
    <logger name="io.github.mbbhalla.agentio" level="DEBUG"/>

    <!-- Suppress MCP SDK noise from non-JSON stdio lines during server startup -->
    <logger name="io.modelcontextprotocol.kotlin.sdk" level="OFF"/>

    <root level="WARN">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
